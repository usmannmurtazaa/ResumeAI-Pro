{
  "name": "resumeai-pro",
  "version": "2.5.0",
  "private": true,
  "description": "Professional ATS Resume Builder with AI-powered optimization - Create stunning, ATS-friendly resumes that land interviews",
  "author": "Usman Murtaza <usman@resumeaipro.com> (https://usmanmurtaza.netlify.app)",
  "license": "MIT",
  "homepage": "https://resumeaixpro.netlify.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/usmannmurtazaa/resumeai-pro.git"
  },
  "bugs": {
    "url": "https://github.com/usmannmurtazaa/resumeai-pro/issues",
    "email": "support@resumeaipro.com"
  },
  "keywords": [
    "resume-builder",
    "ats-resume",
    "cv-maker",
    "job-application",
    "career-tools",
    "resume-templates",
    "ai-resume",
    "firebase",
    "react",
    "tailwindcss",
    "professional-resume",
    "resume-optimizer"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@react-pdf/renderer": "^3.1.14",
    "@sentry/react": "10.49.0",
    "@stripe/react-stripe-js": "^2.4.0",
    "@stripe/stripe-js": "^2.2.0",
    "@tanstack/react-query": "^5.14.0",
    "@tanstack/react-query-devtools": "^5.14.0",
    "axios": "^1.6.2",
    "chart.js": "4.5.1",
    "clsx": "^2.0.0",
    "cross-env": "10.1.0",
    "date-fns": "3.6.0",
    "firebase": "^10.7.1",
    "framer-motion": "^10.17.0",
    "html-to-image": "^1.11.11",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "lodash": "^4.17.21",
    "mammoth": "1.12.0",
    "pdfjs-dist": "3.11.174",
    "react": "^18.3.1",
    "react-chartjs-2": "5.3.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "15.0.0",
    "react-error-boundary": "^4.0.11",
    "react-helmet-async": "^2.0.4",
    "react-hook-form": "^7.49.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^4.12.0",
    "react-intersection-observer": "^9.5.3",
    "react-otp-input": "3.1.1",
    "react-phone-number-input": "3.4.16",
    "react-router-dom": "^6.21.0",
    "react-share": "^5.1.0",
    "recharts": "^2.10.3",
    "tailwind-merge": "^2.2.0",
    "use-debounce": "^10.0.0",
    "uuid": "^9.0.1",
    "web-vitals": "5.2.0",
    "zustand": "4.5.7"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:emulators": "firebase emulators:start --import=./emulator-data --export-on-exit",
    "build": "react-scripts build",
    "build:analyze": "source-map-explorer 'build/static/js/*.js'",
    "build:prod": "react-scripts build",
    "test": "react-scripts test --watchAll=false",
    "test:watch": "react-scripts test",
    "test:coverage": "react-scripts test --coverage --watchAll=false",
    "eject": "react-scripts eject",
    "lint": "eslint src --ext .js,.jsx --max-warnings 0",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "format": "prettier --write 'src/**/*.{js,jsx,json,css,scss,md}'",
    "format:check": "prettier --check 'src/**/*.{js,jsx,json,css,scss,md}'",
    "deploy": "npm run build && firebase deploy",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:firestore": "firebase deploy --only firestore:rules,firestore:indexes",
    "deploy:storage": "firebase deploy --only storage",
    "deploy:staging": "npm run build && firebase deploy --project staging",
    "deploy:production": "npm run build:prod && firebase deploy --project production",
    "emulators": "firebase emulators:start",
    "emulators:export": "firebase emulators:export ./emulator-data",
    "logs": "firebase functions:log",
    "shell": "firebase functions:shell",
    "clean": "rm -rf node_modules build coverage .firebase",
    "clean:install": "npm run clean && npm install",
    "prepare": "husky install || true",
    "pre-commit": "lint-staged",
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "stats": "webpack-bundle-analyzer build/bundle-stats.json",
    "version": "npm version",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags",
    "update:deps": "npx npm-check-updates -u && npm install"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@tailwindcss/aspect-ratio": "0.4.2",
    "@tailwindcss/forms": "0.5.9",
    "@tailwindcss/typography": "0.5.15",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "autoprefixer": "10.4.16",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.2",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "firebase-tools": "^13.0.2",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-watch-typeahead": "^2.2.2",
    "lint-staged": "^15.2.0",
    "postcss": "8.4.31",
    "postcss-import": "^15.1.0",
    "prettier": "^3.1.1",
    "react-scripts": "^5.0.1",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "3.3.5",
    "webpack-bundle-analyzer": "^4.10.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "not IE 11"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run test"
    }
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/**/*.test.{js,jsx}",
      "!src/index.js",
      "!src/serviceWorker.js",
      "!src/**/*.stories.{js,jsx}"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "coverageReporters": [
      "text",
      "html",
      "lcov"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@components/(.*)$": "<rootDir>/src/components/$1",
      "^@pages/(.*)$": "<rootDir>/src/pages/$1",
      "^@hooks/(.*)$": "<rootDir>/src/hooks/$1",
      "^@utils/(.*)$": "<rootDir>/src/utils/$1",
      "^@services/(.*)$": "<rootDir>/src/services/$1",
      "^@contexts/(.*)$": "<rootDir>/src/contexts/$1",
      "^@layouts/(.*)$": "<rootDir>/src/layouts/$1",
      "^@styles/(.*)$": "<rootDir>/src/styles/$1",
      "^@assets/(.*)$": "<rootDir>/src/assets/$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.js"
    ],
    "testEnvironment": "jsdom",
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.{js,jsx}",
      "<rootDir>/src/**/*.{spec,test}.{js,jsx}"
    ],
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|mjs|cjs|ts|tsx)$",
      "^.+\\.module\\.(css|sass|scss)$"
    ],
    "watchPlugins": [
      "jest-watch-typeahead/filename",
      "jest-watch-typeahead/testname"
    ]
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "plugin:import/errors",
      "plugin:import/warnings",
      "plugin:jsx-a11y/recommended",
      "prettier"
    ],
    "plugins": [
      "jsx-a11y",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": "error",
      "import/order": [
        "error",
        {
          "groups": [
            "builtin",
            "external",
            "internal",
            "parent",
            "sibling",
            "index"
          ],
          "newlines-between": "always"
        }
      ],
      "react/react-in-jsx-scope": "off",
      "react/prop-types": "off",
      "no-console": [
        "warn",
        {
          "allow": [
            "warn",
            "error"
          ]
        }
      ]
    },
    "settings": {
      "import/resolver": {
        "node": {
          "extensions": [
            ".js",
            ".jsx"
          ],
          "moduleDirectory": [
            "node_modules",
            "src"
          ]
        }
      }
    }
  },
  "resolutions": {
    "protobufjs": "^7.2.5",
    "nth-check": "^2.1.1",
    "postcss": "^8.4.32"
  },
  "overrides": {
    "protobufjs": "^7.2.5",
    "nth-check": "^2.1.1"
  }
}
