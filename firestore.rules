rules_version = '2';

/**
 * IMPORTANT: Admin dashboards require custom claims matching the client —
 * Prefer Firebase Admin SDK: setCustomUserClaims(uid, { admin: true })
 * Optionally also set role: 'admin' for legacy checks (storage.rules).
 */

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    /** Client AdminRoute verifies admin/superAdmin; rules must mirror JWT claims only. */
    function isPrivilegedAdmin() {
      return signedIn()
        && (request.auth.token.admin == true
            || request.auth.token.superAdmin == true
            || request.auth.token.role == 'admin');
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || isPrivilegedAdmin();
      allow create: if isSelf(userId);
      allow update, delete: if isSelf(userId) || isPrivilegedAdmin();
    }

    match /resumes/{resumeId} {
      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || isPrivilegedAdmin());

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if signedIn()
        && (resource.data.userId == request.auth.uid || isPrivilegedAdmin());
    }

    match /settings/{userId} {
      allow read, write: if isSelf(userId);
    }

    match /notifications/{notificationId} {
      allow read: if signedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /templates/{templateId} {
      allow read: if true;
    }

    /** Billing / Stripe mirror — client reads own doc; writes via Admin SDK or privileged admin */
    match /subscriptions/{userId} {
      allow read: if isSelf(userId) || isPrivilegedAdmin();
      allow create, update: if isPrivilegedAdmin();
      allow delete: if isSelf(userId) || isPrivilegedAdmin();
    }

    /** Product analytics — authenticated events only; userId on document must match caller */
    match /analytics/{docId} {
      allow read: if isPrivilegedAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.keys().hasAll(['userId', 'name'])
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isPrivilegedAdmin();
    }

    /** Session list under user profile (authService) */
    match /users/{userId}/sessions/{sessionId} {
      allow read, create, update, delete: if isSelf(userId);
    }

    /** Soft-delete audit trail */
    match /deletedAccounts/{docId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isPrivilegedAdmin();
    }
  }
}
