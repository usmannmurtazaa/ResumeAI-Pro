rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.uid == userId || 
         request.auth.token.role == 'admin');
      
      function isValidUser() {
        return request.resource.data.email is string &&
               request.resource.data.role in ['user', 'admin', 'premium'] &&
               request.resource.data.email.size() <= 100;
      }
      
      allow create: if request.auth != null && isValidUser();
      allow update: if request.auth != null && isValidUser();
      allow delete: if request.auth != null && request.auth.token.role == 'admin';
    }
    
    // Resumes collection
    match /resumes/{resumeId} {
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         request.auth.token.role == 'admin');
      
      function isValidResume() {
        return request.resource.data.userId == request.auth.uid &&
               request.resource.data.template is string &&
               request.resource.data.data is map;
      }
      
      allow create: if request.auth != null && isValidResume();
      allow update: if request.auth != null && isValidResume();
      allow delete: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         request.auth.token.role == 'admin');
    }
    
    // ATS Scans collection
    match /atsScans/{scanId} {
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         request.auth.token.role == 'admin');
      
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         request.auth.token.role == 'admin');
    }
    
    // User Settings collection
    match /settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Analytics collection (admin only)
    match /analytics/{docId} {
      allow read: if request.auth != null && request.auth.token.role == 'admin';
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
  }
}