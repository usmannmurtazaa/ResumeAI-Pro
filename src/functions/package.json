{
  "name": "functions",
  "version": "1.0.0",
  "description": "Cloud Functions for ATS Resume Builder - AI-Powered Resume Platform",
  "author": "Usman Murtaza",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": "18"
  },
  "main": "index.js",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "serve:all": "firebase emulators:start",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "deploy:prod": "firebase deploy --only functions --project production",
    "deploy:staging": "firebase deploy --only functions --project staging",
    "logs": "firebase functions:log",
    "logs:tail": "firebase functions:log --tail",
    "kill": "lsof -ti:5001,8080,9099,9199 | xargs kill -9 2>/dev/null || true",
    "clean": "rm -rf node_modules package-lock.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "test": "mocha --timeout 5000 --exit",
    "test:watch": "mocha --watch --timeout 5000",
    "test:coverage": "nyc mocha --timeout 5000 --exit",
    "config:get": "firebase functions:config:get",
    "config:set": "firebase functions:config:set",
    "config:unset": "firebase functions:config:unset",
    "secrets:set": "firebase functions:secrets:set",
    "secrets:access": "firebase functions:secrets:access"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.7.0",
    "@google-cloud/tasks": "^5.3.0",
    "@sendgrid/mail": "^8.1.0",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.6.0",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.8",
    "openai": "^4.24.1",
    "pdfkit": "^0.14.0",
    "puppeteer": "^21.6.1",
    "puppeteer-core": "^21.6.1",
    "qrcode": "^1.5.3",
    "redis": "^4.6.12",
    "sanitize-html": "^2.11.0",
    "sharp": "^0.33.1",
    "stripe": "^14.12.0",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "chai": "^4.3.10",
    "eslint": "^8.56.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.2",
    "eslint-plugin-promise": "^6.1.1",
    "firebase-functions-test": "^3.1.1",
    "jest": "^29.7.0",
    "mocha": "^10.2.0",
    "nodemon": "^3.0.2",
    "nyc": "^15.1.0",
    "prettier": "^3.1.1",
    "sinon": "^17.0.1",
    "supertest": "^6.3.3"
  },
  "resolutions": {
    "protobufjs": "^7.2.5"
  },
  "overrides": {
    "protobufjs": "^7.2.5"
  },
  "config": {
    "firebase": {
      "region": "us-central1",
      "memory": "256MB",
      "timeout": "60s",
      "minInstances": 0,
      "maxInstances": 10
    }
  },
  "engines-comment": {
    "node": "Node.js 18 is the minimum supported version for Firebase Functions v2"
  },
  "scripts-comment": {
    "serve": "Start Firebase emulators for local development",
    "deploy": "Deploy functions to Firebase",
    "logs": "View function logs",
    "test": "Run unit tests",
    "lint": "Check code quality"
  },
  "dependencies-comment": {
    "firebase-admin": "Firebase Admin SDK for server-side operations",
    "firebase-functions": "Firebase Functions SDK",
    "nodemailer": "Email sending functionality",
    "puppeteer": "Headless Chrome for PDF generation",
    "sharp": "Image processing",
    "stripe": "Payment processing",
    "openai": "AI-powered suggestions",
    "winston": "Advanced logging"
  }
}