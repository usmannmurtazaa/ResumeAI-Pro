rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    /** Align with AdminRoute/Firestore: admin booleans preferred; legacy `role` tolerated. */
    function isPrivilegedAdmin() {
      return signedIn()
        && (request.auth.token.admin == true
            || request.auth.token.superAdmin == true
            || request.auth.token.role == 'admin');
    }

    function isPdfOrDocMime() {
      return request.resource != null &&
        request.resource.size < 10 * 1024 * 1024 &&
        (
          request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('application/vnd\\.openxmlformats-officedocument\\..*')
          || request.resource.contentType.matches('application/msword')
        );
    }

    function isResumeStorageMime() {
      return request.resource != null &&
        request.resource.size < 10 * 1024 * 1024 &&
        (
          isPdfOrDocMime()
          || request.resource.contentType.matches('text/plain')
        );
    }

    function isAvatarMime() {
      return request.resource != null &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    match /resumes/{userId}/{allPaths=**} {
      allow read: if signedIn()
        && (request.auth.uid == userId || isPrivilegedAdmin());
      allow write: if signedIn()
        && request.auth.uid == userId
        && isResumeStorageMime();
      allow delete: if signedIn()
        && (request.auth.uid == userId || isPrivilegedAdmin());
    }

    match /scans/{userId}/{allPaths=**} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if signedIn()
        && request.auth.uid == userId
        && isResumeStorageMime();
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /avatars/{userId}/{allPaths=**} {
      allow read: if signedIn()
        && (request.auth.uid == userId || isPrivilegedAdmin());
      allow write: if signedIn()
        && request.auth.uid == userId
        && isAvatarMime();
      allow delete: if signedIn()
        && (request.auth.uid == userId || isPrivilegedAdmin());
    }

    match /templates/{allPaths=**} {
      allow read: if true;
      allow write: if isPrivilegedAdmin();
    }

    /**
     * No catch-all grants: a previous permissive `{allPaths=**}` rule allowed any authenticated
     * user to satisfy size/MIME constraints on arbitrary paths. Default deny implicitly applies.
     */
  }
}
