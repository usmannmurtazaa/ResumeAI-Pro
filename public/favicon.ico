<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
  <defs>
    <linearGradient id="darkGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#818cf8" />
      <stop offset="100%" style="stop-color:#c084fc" />
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="2" result="blur" />
      <feComposite in="SourceGraphic" in2="blur" operator="over" />
    </filter>
  </defs>
  
  <!-- Dark background -->
  <rect width="100" height="100" rx="24" fill="#1e1e2e" />
  
  <!-- Gradient icon background -->
  <rect x="15" y="15" width="70" height="70" rx="16" fill="url(#darkGrad)" opacity="0.15" />
  
  <!-- Icon elements -->
  <path d="M30 40 L50 28 L70 40" stroke="url(#darkGrad)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none" filter="url(#glow)"/>
  <path d="M35 48 L50 40 L65 48" stroke="url(#darkGrad)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.7"/>
  <path d="M40 56 L50 50 L60 56" stroke="url(#darkGrad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.5"/>
  
  <text x="50" y="78" font-family="'Inter', Arial, sans-serif" font-size="14" font-weight="800" fill="url(#darkGrad)" text-anchor="middle">AI</text>
</svg>